<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="NPRSApp.Maui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:NPRSApp.Maui"
    xmlns:views="clr-namespace:NPRSApp.Maui.Views"
    Title="NPRS App">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />


    <ShellContent
    Title="Reports"
    ContentTemplate="{DataTemplate views:ReportListPage}" />

    <ShellContent
        Title="New Report"
        ContentTemplate="{DataTemplate views:NewReportPage}" />

</Shell>
