<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="NPRSApp.Maui.Views.NewReportPage"
    Title="NewReportPage">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">

            <!-- Reporter Info -->
            <Entry
                Placeholder="Reporter Name"
                Text="{Binding ReporterName}" />

            <Entry
                Placeholder="Phone"
                Text="{Binding ReporterPhone}" />

            <Entry
                Placeholder="Email"
                Text="{Binding ReporterEmail}" />

            <!-- Incident Info -->
            <Entry
                Placeholder="Incident Type"
                Text="{Binding IncidentType}" />

            <DatePicker Date="{Binding IncidentDate}" />

            <Entry
                Placeholder="Location"
                Text="{Binding IncidentLocation}" />

            <Editor
                Placeholder="Description"
                HeightRequest="100"
                Text="{Binding Description}" />

            <!-- Submit Button -->
            <Button
                Text="Submit Report"
                Command="{Binding SaveCommand}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>