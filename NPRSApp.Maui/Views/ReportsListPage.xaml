<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="NPRSApp.Maui.Views.ReportListPage"
    Title="Reports">

    <VerticalStackLayout Padding="20" Spacing="10">

        <Label Text="Reports"
               FontSize="24"
               HorizontalOptions="Center" />

        <CollectionView ItemsSource="{Binding Reports}"
                        SelectionMode="Single"
                        SelectionChanged="OnSelectionChanged">
            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <!-- ✅ Using Border instead of Frame -->
                    <Border Stroke="Gray"
                            StrokeThickness="1"
                            Padding="10"
                            Margin="5">

                        <VerticalStackLayout>
                            <Label Text="{Binding ReporterName}"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding IncidentType}" />
                            <Label Text="{Binding IncidentLocation}" />
                        </VerticalStackLayout>

                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="Add New Report"
                Command="{Binding AddReportCommand}" />

    </VerticalStackLayout>

</ContentPage>



